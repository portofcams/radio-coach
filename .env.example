# Copy from cleared/.env
ANTHROPIC_API_KEY=

# Copy from ~/jarvis/.env or your ElevenLabs dashboard
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Only read by the native (iOS) build — the locally bundled app has no origin
# server of its own, so every /api/ fetch gets redirected here at runtime.
NEXT_PUBLIC_API_BASE=https://clearsparradio.binnacleai.com

# iOS IAP needs no keys: StoreKit 2 transactions are Apple-signed JWS,
# verified server-side against Apple's public root certs (src/lib/apple-certs.ts).
